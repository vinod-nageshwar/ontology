    <!-- http://www.semanticweb.org/vinod/ontologies/2026/6/northwind#category1 -->

    <owl:NamedIndividual rdf:about="http://www.semanticweb.org/vinod/ontologies/2026/6/northwind#category1">
        <rdf:type rdf:resource="http://www.semanticweb.org/vinod/ontologies/2026/6/northwind#Category"/>
        <northwind:category_description>Soft drinks, coffees, teas, beers, and ales</northwind:category_description>
        <northwind:category_id rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">1</northwind:category_id>
        <northwind:category_name>Beverages</northwind:category_name>
