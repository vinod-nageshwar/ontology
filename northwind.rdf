    <!-- http://www.semanticweb.org/vinod/ontologies/2026/6/northwind#employee1 -->

    <owl:NamedIndividual rdf:about="http://www.semanticweb.org/vinod/ontologies/2026/6/northwind#employee1">
        <rdf:type rdf:resource="http://www.semanticweb.org/vinod/ontologies/2026/6/northwind#Employee"/>
